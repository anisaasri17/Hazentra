<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hazentra_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/hazentra_navy"
        android:elevation="0dp"

        android:title="Hazard Map"
        android:titleTextColor="@color/hazentra_white"

        app:titleCentered="true"

        app:menu="@menu/main_menu"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Google Map -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar" />

    <!-- Hazard marker legend -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mapLegendCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/hazentra_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:strokeColor="@color/hazentra_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="15dp"
            android:paddingEnd="18dp"
            android:paddingBottom="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="11dp"
                android:text="Hazard Legend"
                android:textColor="@color/hazentra_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Road hazard -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/legend_dot_red" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Road Hazard"
                    android:textColor="@color/hazentra_text"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Environmental hazard -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/legend_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Environmental Hazard"
                    android:textColor="@color/hazentra_text"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Building hazard -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/legend_dot_orange" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Building Hazard"
                    android:textColor="@color/hazentra_text"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Refresh hazard markers -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/refreshHazardsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Refresh hazard markers"
        app:backgroundTint="@color/hazentra_navy"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="@color/hazentra_navy_light"
        app:srcCompat="@drawable/ic_refresh"
        app:tint="@color/hazentra_on_navy" />

    <!-- Report hazard button -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/reportHazardButton"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Open hazard report form"
        android:text="Report Hazard"
        android:textAllCaps="false"
        android:textColor="@color/hazentra_on_orange"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/hazentra_orange"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_input_add"
        app:iconPadding="10dp"
        app:iconTint="@color/hazentra_on_orange"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="@color/hazentra_orange_dark" />
    <com.google.android.material.progressindicator.CircularProgressIndicator

        android:id="@+id/loadingIndicator"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:visibility="gone"
        app:indicatorSize="56dp"
        app:trackThickness="5dp"
        app:indicatorColor="@color/hazentra_orange"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>