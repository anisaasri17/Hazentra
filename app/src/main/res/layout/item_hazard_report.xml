<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="7dp"
    android:layout_marginBottom="7dp"
    app:cardBackgroundColor="@color/hazentra_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/hazentra_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/itemCategoryText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Road Hazard"
                android:textColor="@color/hazentra_red"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/itemStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/status_active_background"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="Active"
                android:textColor="@color/hazentra_warning_green"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/itemLocationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Location: Unknown"
            android:textColor="@color/hazentra_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/itemDescriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:maxLines="4"
            android:text="No description available."
            android:textColor="@color/hazentra_text"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:background="@color/hazentra_divider" />

        <TextView
            android:id="@+id/itemReporterText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reported by: Unknown"
            android:textColor="@color/hazentra_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/itemDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Reported on: Unknown"
            android:textColor="@color/hazentra_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/itemCoordinatesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Coordinates: 0.000000, 0.000000"
            android:textColor="@color/hazentra_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/itemDeviceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Device: Unknown"
            android:textColor="@color/hazentra_muted"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>