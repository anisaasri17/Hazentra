<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hazentra_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/statisticsToolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/hazentra_navy"
            android:elevation="0dp"
            android:title="Statistics"
            android:titleTextColor="@color/hazentra_on_navy"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/hazentra_on_navy"
            app:titleCentered="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Statistics Dashboard"
                android:textColor="@color/hazentra_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Live statistics calculated from active hazard reports."
                android:textColor="@color/hazentra_muted"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="@color/hazentra_navy"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL ACTIVE HAZARDS"
                        android:textColor="@color/hazentra_orange"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/totalHazardsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/hazentra_on_navy"
                        android:textSize="46sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Reports currently displayed on the map"
                        android:textColor="#D7E1EC"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/hazentra_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/hazentra_outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/legend_dot_red" />

                        <TextView
                            android:id="@+id/roadHazardsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textColor="@color/hazentra_red"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Road Hazards"
                            android:textColor="@color/hazentra_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/hazentra_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/hazentra_outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/legend_dot_green" />

                        <TextView
                            android:id="@+id/environmentalHazardsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textColor="@color/hazentra_warning_green"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="Environmental"
                            android:textColor="@color/hazentra_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/hazentra_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/hazentra_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@drawable/legend_dot_orange" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Building Hazards"
                            android:textColor="@color/hazentra_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Active building-related reports"
                            android:textColor="@color/hazentra_muted"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/buildingHazardsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/hazentra_warning_orange"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Hazards by Category"
                android:textColor="@color/hazentra_text"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Comparison of active reports across the three hazard categories"
                android:textColor="@color/hazentra_muted"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/categoryChartCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/hazentra_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/hazentra_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Road"
                            android:textColor="@color/hazentra_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/roadChartCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/hazentra_red"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/roadBarTrack"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/hazentra_outline">

                        <View
                            android:id="@+id/roadBarFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@color/hazentra_red" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Environmental"
                            android:textColor="@color/hazentra_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/environmentalChartCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/hazentra_warning_green"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/environmentalBarTrack"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/hazentra_outline">

                        <View
                            android:id="@+id/environmentalBarFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@color/hazentra_warning_green" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Building"
                            android:textColor="@color/hazentra_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/buildingChartCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/hazentra_warning_orange"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/buildingBarTrack"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="8dp"
                        android:background="@color/hazentra_outline">

                        <View
                            android:id="@+id/buildingBarFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@color/hazentra_warning_orange" />

                    </FrameLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Latest Hazard Report"
                android:textColor="@color/hazentra_text"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Most recently submitted active report"
                android:textColor="@color/hazentra_muted"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/latestReportCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/hazentra_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/hazentra_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="21dp">

                    <TextView
                        android:id="@+id/latestCategoryText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Road Hazard"
                        android:textColor="@color/hazentra_red"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/latestLocationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Location: Unknown"
                        android:textColor="@color/hazentra_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/latestDescriptionText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:lineSpacingExtra="3dp"
                        android:text="No description available."
                        android:textColor="@color/hazentra_text"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="13dp"
                        android:background="@color/hazentra_divider" />

                    <TextView
                        android:id="@+id/latestReporterText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reported by: Unknown"
                        android:textColor="@color/hazentra_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/latestDateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Reported on: Unknown"
                        android:textColor="@color/hazentra_muted"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/emptyStatisticsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:padding="20dp"
                android:text="No active hazard reports are currently available."
                android:textColor="@color/hazentra_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/statisticsLoadingIndicator"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                app:indicatorColor="@color/hazentra_orange"
                app:indicatorSize="52dp"
                app:trackThickness="5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/retryStatisticsButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:text="Retry"
                android:textAllCaps="false"
                android:textColor="@color/hazentra_orange"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@color/hazentra_surface"
                app:cornerRadius="14dp"
                app:strokeColor="@color/hazentra_orange"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>